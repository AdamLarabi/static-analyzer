# ==============================================================================
# Configuration de l'environnement Static Analyzer
# À renommer en .env et à compléter avec vos valeurs
# ==============================================================================

# Clé secrète pour les sessions (utiliser une chaîne aléatoire complexe)
# Exemples : python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=votre_cle_secrete_super_complexe

# Clé API VirusTotal (obligatoire pour la vérification de réputation)
VT_API_KEY=VOTRE_CLE_API_VIRUSTOTAL

# Mot de passe par défaut pour le compte administrateur lors de l'initialisation
ADMIN_DEFAULT_PASSWORD=ChangeMe!2026

# Mode de l'application (development / production)
FLASK_ENV=production

# Sécuriser les cookies de session via HTTPS (true en production, false en dev)
HTTPS=false

# Niveau de journalisation (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Base de données (par défaut: sqlite:///database/analyzer.db)
# DATABASE_URL=mysql://user:pass@localhost/db_name
